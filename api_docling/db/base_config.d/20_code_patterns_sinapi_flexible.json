{
  "knowledge_base": {
    "code_patterns": [
      {
        "id": "sinapi_composition_flexible_separator",
        "family": "sinapi_like",
        "regex": "^(?:\\d{4,6}|\\d{4,6}[/-][0-9A-Z]{1,6}(?:[/-][0-9A-Z]{1,6})?)$",
        "examples": [
          "74209/001",
          "103672-01"
        ],
        "negative_examples": [
          "6,05",
          "1.234,56"
        ],
        "description": "Variante flexível para códigos SINAPI com / ou -, sem aceitar dinheiro."
      }
    ]
  }
}